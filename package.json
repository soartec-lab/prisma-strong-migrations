{
  "name": "strong-prisma",
  "version": "0.1.0",
  "description": "Catch unsafe Prisma migrations before they run. Detects dangerous operations like dropping columns, adding indexes without CONCURRENTLY, and more.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "strong-prisma": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "jest",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "prisma",
    "migrations",
    "safety",
    "database"
  ],
  "author": "Shodai Suzuki",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.3",
    "typescript": "^5.4.5"
  }
}
